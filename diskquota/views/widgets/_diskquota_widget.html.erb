<!--
    DiskQuota widget for showing a warning box when some directory is near quota
  -->
<style>
  .diskquota-widget {
      display: none;
  }
  .diskquota-widget:has(li) {
      display: block;
      margin-top: 16px;
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const container = document.getElementById("diskquota-widget-list");
  if (!container) return;

  const url = container.dataset.src;
  if (!url) return;

  fetch(url, { headers: { "Accept": "text/html" } })
    .then(response => {
      if (!response.ok) throw new Error("Failed to load widget");
      return response.text();
    })
    .then(html => {
      container.innerHTML = html;
    })
    .catch(err => {
      console.error(err);
    });
});
</script>

<div class='diskquota-widget warning alert alert-warning card'>
  <p>The following directories are almost full, see how to check them in
    <a href="https://www.c3se.chalmers.se/documentation/file_transfer/filesystem/">
      our documentation.</a>
  </p>
  <div id="diskquota-widget-list"
       data-src="<%= diskquota_widget_list_path %>">
  </div>
</div>
